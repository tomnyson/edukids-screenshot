{
  "name": "screenshot-tool",
  "description": "Screenshot capture and annotation tool",
  "author": "Screenshot Tool",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "lucide-react": "latest",
    "fabric": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "electron": "latest",
    "vite-plugin-electron": "latest",
    "vite-plugin-electron-renderer": "latest",
    "electron-builder": "latest",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "esbuild": "latest"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.screenshot-tool.app",
    "productName": "Screenshot Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist-electron/preload.js"
    ],
    "extraResources": [
      { "from": "build/tray-icon.png", "to": "build/tray-icon.png" }
    ],
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "icon": "build/icon.png"
    }
  }
}